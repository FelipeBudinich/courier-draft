{% extends "layouts/app.njk" %}

{% block title %}{{ title }} · {{ t('meta.appName') }}{% endblock %}

{% block content %}
  <section class="hero-panel">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent">{{ project.publicId }}</p>
    <h2 class="mt-3 text-4xl text-ink">{{ headingKey and t(headingKey) or project.name }}</h2>
    <p class="mt-3 max-w-3xl text-lg leading-8 text-ink/70">
      {{ descriptionKey and t(descriptionKey) or project.description }}
    </p>
  </section>

  {% if scripts %}
    <section class="panel space-y-4">
      <h3 class="text-2xl text-ink">{{ t('sections.scripts') }}</h3>
      {% if scripts.length %}
        <div class="space-y-3">
          {% for script in scripts %}
            <article class="list-card flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
              <div>
                <p class="font-semibold text-ink">{{ script.title }}</p>
                <p class="text-sm text-ink/60">{{ script.sceneNumberMode }} · {{ formatDate(script.updatedAt) }}</p>
              </div>
              <a class="btn-primary" href="/projects/{{ project.publicId }}/scripts/{{ script.publicId }}">{{ t('shared.buttons.openScript') }}</a>
            </article>
          {% endfor %}
        </div>
      {% else %}
        <p class="text-sm text-ink/60">{{ t('shared.empty.generic') }}</p>
      {% endif %}
    </section>
  {% endif %}

  {% if members %}
    <section class="panel space-y-4">
      <h3 class="text-2xl text-ink">{{ t('sections.members') }}</h3>
      {% if members.length %}
        <div class="space-y-3">
          {% for member in members %}
            <article class="list-card flex items-center justify-between gap-4">
              <div>
                <p class="font-semibold text-ink">{{ member.userId.displayName if member.userId else member.role }}</p>
                <p class="text-sm text-ink/60">{{ member.userId.email if member.userId else '' }}</p>
              </div>
              <span class="badge">{{ t('shared.badges.' + member.role) }}</span>
            </article>
          {% endfor %}
        </div>
      {% else %}
        <p class="text-sm text-ink/60">{{ t('shared.empty.members') }}</p>
      {% endif %}
    </section>
  {% endif %}

  {% if activity %}
    <section class="panel space-y-4">
      <h3 class="text-2xl text-ink">{{ t('sections.activity') }}</h3>
      {% if activity.length %}
        <div class="space-y-3">
          {% for item in activity %}
            <article class="list-card">
              <p class="font-semibold text-ink">{{ item.message }}</p>
              <p class="text-xs text-ink/50">{{ formatDate(item.createdAt) }}</p>
            </article>
          {% endfor %}
        </div>
      {% else %}
        <p class="text-sm text-ink/60">{{ t('shared.empty.activity') }}</p>
      {% endif %}
    </section>
  {% endif %}

  {% if auditLogs %}
    <section class="panel space-y-4">
      <h3 class="text-2xl text-ink">{{ t('sections.audit') }}</h3>
      {% if auditLogs.length %}
        <div class="space-y-3">
          {% for item in auditLogs %}
            <article class="list-card">
              <p class="font-semibold text-ink">{{ item.action }}</p>
              <p class="text-sm text-ink/60">{{ item.targetType }} · {{ item.targetId }}</p>
              <p class="text-xs text-ink/50">{{ formatDate(item.createdAt) }}</p>
            </article>
          {% endfor %}
        </div>
      {% else %}
        <p class="text-sm text-ink/60">{{ t('shared.empty.generic') }}</p>
      {% endif %}
    </section>
  {% endif %}

  {% if entities %}
    <section class="panel space-y-4">
      <h3 class="text-2xl text-ink">{{ t('sections.entities') }}</h3>
      {% if entities.length %}
        <div class="space-y-3">
          {% for entity in entities %}
            <article class="list-card">
              <p class="font-semibold text-ink">{{ entity.canonicalName }}</p>
              <p class="text-sm text-ink/60">{{ entity.type }}</p>
            </article>
          {% endfor %}
        </div>
      {% else %}
        <p class="text-sm text-ink/60">{{ t('shared.empty.generic') }}</p>
      {% endif %}
    </section>
  {% endif %}
{% endblock %}

