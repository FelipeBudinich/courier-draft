{% extends "layouts/app.njk" %}

{% block title %}{{ script.title }} · {{ t('pages.script.heading') }}{% endblock %}

{% block content %}
  <div
    class="space-y-6"
    data-script-shell
    data-project-id="{{ project.id }}"
    data-script-id="{{ script.id }}"
    data-outline-fragment-url="/fragments/projects/{{ project.id }}/scripts/{{ script.id }}/outline-tree"
  >
    <section class="hero-panel">
      <div class="flex flex-wrap items-center gap-3">
        <span class="badge">{{ t('shared.badges.' + currentRole) }}</span>
        <span class="badge">{{ script.sceneNumberMode | upper }}</span>
        <span class="text-sm text-ink/55" data-script-connection-state>{{ t('pages.projectOverview.connecting') }}</span>
      </div>
      <h2 class="mt-4 text-4xl text-ink" data-script-title>{{ script.title }}</h2>
      <p class="mt-3 max-w-3xl text-lg leading-8 text-ink/70">{{ t('pages.script.description') }}</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a class="btn-primary" href="/projects/{{ project.id }}/scripts/{{ script.id }}/editor">{{ t('shared.buttons.openEditor') }}</a>
        <a class="btn-secondary" href="/projects/{{ project.id }}">{{ t('shared.buttons.openProject') }}</a>
      </div>
    </section>

    <section class="grid gap-6 xl:grid-cols-[1.15fr,0.85fr]">
      <div class="space-y-6">
        <article class="panel space-y-5">
          <div class="flex items-center justify-between gap-3">
            <div>
              <h3 class="text-2xl text-ink">{{ t('pages.scriptSections.metadata') }}</h3>
              <p class="text-sm text-ink/60">{{ t('pages.scriptSections.metadataHelp') }}</p>
            </div>
            {% if not permissions.canEdit %}
              <span class="badge">{{ t('pages.editor.readOnly') }}</span>
            {% endif %}
          </div>

          <form
            class="space-y-6"
            data-script-metadata-form
            data-project-id="{{ project.id }}"
            data-script-id="{{ script.id }}"
          >
            <div class="grid gap-5 lg:grid-cols-2">
              <label class="space-y-2">
                <span class="text-sm font-semibold text-ink">{{ t('pages.scriptFields.title') }}</span>
                <input class="input" type="text" name="title" maxlength="160" value="{{ script.title }}" {% if not permissions.canEdit %}disabled{% endif %} required />
              </label>
              <label class="space-y-2">
                <span class="text-sm font-semibold text-ink">{{ t('pages.scriptFields.status') }}</span>
                <input class="input" type="text" name="status" maxlength="60" value="{{ script.status }}" {% if not permissions.canEdit %}disabled{% endif %} />
              </label>
              <label class="space-y-2 lg:col-span-2">
                <span class="text-sm font-semibold text-ink">{{ t('pages.scriptFields.description') }}</span>
                <textarea class="input min-h-32" name="description" maxlength="2000" {% if not permissions.canEdit %}disabled{% endif %}>{{ script.description }}</textarea>
              </label>
              <label class="space-y-2">
                <span class="text-sm font-semibold text-ink">{{ t('pages.scriptFields.genre') }}</span>
                <input class="input" type="text" name="genre" maxlength="120" value="{{ script.genre }}" {% if not permissions.canEdit %}disabled{% endif %} />
              </label>
              <label class="space-y-2">
                <span class="text-sm font-semibold text-ink">{{ t('pages.scriptFields.language') }}</span>
                <input class="input" type="text" name="language" maxlength="60" value="{{ script.language }}" {% if not permissions.canEdit %}disabled{% endif %} />
              </label>
            </div>

            <section class="space-y-3">
              <div class="flex items-center justify-between gap-3">
                <div>
                  <h4 class="text-xl text-ink">{{ t('pages.scriptFields.authors') }}</h4>
                  <p class="text-sm text-ink/60">{{ t('pages.scriptFields.authorsHelp') }}</p>
                </div>
                {% if permissions.canEdit %}
                  <button class="btn-secondary" type="button" data-authors-add>{{ t('pages.scriptActions.addAuthor') }}</button>
                {% endif %}
              </div>
              <div class="space-y-3" data-authors-list>
                {% for author in script.authors %}
                  <div class="flex flex-wrap items-center gap-2" data-author-row>
                    <input class="input min-w-[14rem] flex-1" type="text" name="authors" value="{{ author }}" {% if not permissions.canEdit %}disabled{% endif %} />
                    {% if permissions.canEdit %}
                      <button class="btn-secondary" type="button" data-author-move="-1">{{ t('pages.scriptActions.moveUp') }}</button>
                      <button class="btn-secondary" type="button" data-author-move="1">{{ t('pages.scriptActions.moveDown') }}</button>
                      <button class="btn-secondary" type="button" data-author-remove>{{ t('pages.scriptActions.remove') }}</button>
                    {% endif %}
                  </div>
                {% endfor %}
              </div>
            </section>

            {% if permissions.canEdit %}
              <div class="flex flex-wrap items-center gap-3">
                <button class="btn-primary" type="submit">{{ t('shared.buttons.save') }}</button>
                <p class="text-sm text-ink/55" data-form-status></p>
              </div>
            {% endif %}
          </form>
        </article>

        <article class="panel space-y-4">
          <div class="flex items-center justify-between gap-3">
            <div>
              <h3 class="text-2xl text-ink">{{ t('pages.scriptSections.numbering') }}</h3>
              <p class="text-sm text-ink/60">{{ t('pages.scriptSections.numberingHelp') }}</p>
            </div>
          </div>
          <form
            class="flex flex-wrap items-center gap-3"
            data-scene-number-form
            data-project-id="{{ project.id }}"
            data-script-id="{{ script.id }}"
          >
            <select class="input min-w-[14rem]" name="sceneNumberMode" {% if not permissions.canEdit %}disabled{% endif %}>
              <option value="off" {% if script.sceneNumberMode == 'off' %}selected{% endif %}>OFF</option>
              <option value="auto" {% if script.sceneNumberMode == 'auto' %}selected{% endif %}>AUTO</option>
              <option value="frozen" {% if script.sceneNumberMode == 'frozen' %}selected{% endif %}>FROZEN</option>
            </select>
            {% if permissions.canEdit %}
              <button class="btn-primary" type="submit">{{ t('shared.buttons.save') }}</button>
            {% endif %}
            <p class="text-sm text-ink/55" data-form-status></p>
          </form>
        </article>

        <div data-outline-fragment-target>
          {% include "partials/outline-tree.njk" %}
        </div>
      </div>

      <div class="space-y-6">
        <div
          data-notes-shell
          data-project-id="{{ project.id }}"
          data-script-id="{{ script.id }}"
          data-notes-surface="script"
          data-notes-fragment-url="/fragments/projects/{{ project.id }}/scripts/{{ script.id }}/notes-panel"
        >
          <div data-notes-fragment-target>
            {% include "partials/notes-panel.njk" %}
          </div>
        </div>

        {% include "partials/activity-feed.njk" %}

        <article class="panel space-y-4">
          <h3 class="text-2xl text-ink">{{ t('pages.scriptSections.summary') }}</h3>
          <div class="space-y-2 text-sm text-ink/70">
            <p>{{ t('pages.scriptFields.created') }}: {{ formatDate(script.createdAt) }}</p>
            <p>{{ t('pages.scriptFields.updated') }}: {{ formatDate(script.updatedAt) }}</p>
            <p>{{ t('pages.scriptFields.totalNodes') }}: {{ script.counts.totalNodes }}</p>
            <p>{{ t('pages.scriptFields.totalScenes') }}: {{ script.counts.sceneCount }}</p>
          </div>
        </article>

        {% if permissions.canDelete %}
          <article class="panel space-y-4">
            <h3 class="text-2xl text-ink">{{ t('pages.scriptActions.dangerZone') }}</h3>
            <p class="text-sm text-ink/60">{{ t('pages.scriptActions.deleteHelp') }}</p>
            <button
              class="btn-secondary"
              type="button"
              data-script-delete
              data-project-id="{{ project.id }}"
              data-script-id="{{ script.id }}"
              data-redirect-url="/projects/{{ project.id }}"
            >
              {{ t('pages.scriptActions.deleteScript') }}
            </button>
          </article>
        {% endif %}
      </div>
    </section>
  </div>
{% endblock %}
