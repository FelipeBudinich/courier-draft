{% extends "layouts/app.njk" %}

{% block title %}{{ t('pages.newScript.title') }} · {{ t('meta.appName') }}{% endblock %}

{% block content %}
  <section class="hero-panel">
    <div class="flex flex-wrap items-center gap-3">
      <span class="badge">{{ t('shared.badges.' + currentRole) }}</span>
      <span class="badge">{{ project.title }}</span>
    </div>
    <h2 class="mt-4 text-4xl text-ink">{{ t('pages.newScript.heading') }}</h2>
    <p class="mt-3 max-w-3xl text-lg leading-8 text-ink/70">{{ t('pages.newScript.description') }}</p>
  </section>

  <section class="panel">
    <form
      class="space-y-6"
      data-script-create-form
      data-project-id="{{ project.id }}"
    >
      <div class="grid gap-5 lg:grid-cols-2">
        <label class="space-y-2">
          <span class="text-sm font-semibold text-ink">{{ t('pages.scriptFields.title') }}</span>
          <input class="input" type="text" name="title" maxlength="160" required />
        </label>
        <label class="space-y-2">
          <span class="text-sm font-semibold text-ink">{{ t('pages.scriptFields.status') }}</span>
          <input class="input" type="text" name="status" maxlength="60" value="draft" />
        </label>
        <label class="space-y-2 lg:col-span-2">
          <span class="text-sm font-semibold text-ink">{{ t('pages.scriptFields.description') }}</span>
          <textarea class="input min-h-32" name="description" maxlength="2000"></textarea>
        </label>
        <label class="space-y-2">
          <span class="text-sm font-semibold text-ink">{{ t('pages.scriptFields.genre') }}</span>
          <input class="input" type="text" name="genre" maxlength="120" />
        </label>
        <label class="space-y-2">
          <span class="text-sm font-semibold text-ink">{{ t('pages.scriptFields.language') }}</span>
          <input class="input" type="text" name="language" maxlength="60" />
        </label>
      </div>

      <section class="space-y-3">
        <div class="flex items-center justify-between gap-3">
          <div>
            <h3 class="text-2xl text-ink">{{ t('pages.scriptFields.authors') }}</h3>
            <p class="text-sm text-ink/60">{{ t('pages.scriptFields.authorsHelp') }}</p>
          </div>
          <button class="btn-secondary" type="button" data-authors-add>{{ t('pages.scriptActions.addAuthor') }}</button>
        </div>
        <div class="space-y-3" data-authors-list></div>
      </section>

      <div class="flex flex-wrap items-center gap-3">
        <button class="btn-primary" type="submit">{{ t('pages.scriptActions.createScript') }}</button>
        <a class="btn-secondary" href="/projects/{{ project.id }}">{{ t('pages.scriptActions.cancel') }}</a>
        <p class="text-sm text-ink/55" data-form-status></p>
      </div>
    </form>
  </section>
{% endblock %}
