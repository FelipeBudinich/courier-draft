{% extends "layouts/app.njk" %}

{% block title %}{{ t('pages.newProject.title') }} · {{ t('meta.appName') }}{% endblock %}

{% block content %}
  <section class="hero-panel">
    <h2 class="text-4xl text-ink">{{ t('pages.newProject.heading') }}</h2>
    <p class="mt-3 max-w-3xl text-lg leading-8 text-ink/70">{{ t('pages.newProject.description') }}</p>
  </section>
  <section class="panel">
    <form class="space-y-4" data-project-create-form>
      <div>
        <label class="field-label" for="project-title">{{ t('shared.labels.projectTitle') }}</label>
        <input class="field-input" id="project-title" name="title" type="text" maxlength="120" required />
      </div>
      <div class="flex items-center gap-3">
        <button class="btn-primary" type="submit">{{ t('shared.buttons.createProject') }}</button>
        <span class="text-sm text-ink/55" data-form-status></span>
      </div>
    </form>
  </section>
{% endblock %}
