{% extends "layouts/app.njk" %}

{% block title %}{{ project.title }} · {{ t('sections.audit') }}{% endblock %}

{% block content %}
  <section class="hero-panel">
    <h2 class="text-4xl text-ink">{{ t('pages.projectAudit.heading') }}</h2>
    <p class="mt-3 max-w-3xl text-lg leading-8 text-ink/70">{{ t('pages.projectAudit.description') }}</p>
  </section>
  <section class="panel space-y-4">
    <h3 class="text-2xl text-ink">{{ t('sections.audit') }}</h3>
    {% if audit.length %}
      <div class="space-y-3">
        {% for item in audit %}
          <article class="list-card">
            <p class="font-semibold text-ink">{{ item.action }}</p>
            <p class="mt-1 text-sm text-ink/60">{{ item.targetType }} · {{ item.targetId }}</p>
            <p class="mt-1 text-xs text-ink/50">{{ formatDate(item.createdAt) }}</p>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <p class="text-sm text-ink/60">{{ t('shared.empty.generic') }}</p>
    {% endif %}
  </section>
{% endblock %}
