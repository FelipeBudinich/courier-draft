{% extends "layouts/app.njk" %}

{% block title %}{{ project.title }} · {{ t('sections.members') }}{% endblock %}

{% block content %}
  <section class="hero-panel">
    <h2 class="text-4xl text-ink">{{ t('pages.projectMembers.heading') }}</h2>
    <p class="mt-3 max-w-3xl text-lg leading-8 text-ink/70">{{ t('pages.projectMembers.description') }}</p>
    <div class="mt-5 flex flex-wrap gap-3">
      <a class="btn-secondary" href="/projects/{{ project.id }}">{{ t('shared.buttons.openProject') }}</a>
      {% if canManageMembers %}
        <a class="btn-secondary" href="/projects/{{ project.id }}/settings">{{ t('pages.projectSettings.heading') }}</a>
      {% endif %}
    </div>
  </section>
  {% if canManageMembers %}
    <section class="panel space-y-4">
      <div>
        <h3 class="text-2xl text-ink">{{ t('pages.projectMembers.inviteHeading') }}</h3>
        <p class="mt-2 text-sm leading-7 text-ink/65">{{ t('pages.projectMembers.inviteDescription') }}</p>
      </div>
      <form class="space-y-4" data-invite-form data-project-id="{{ project.id }}">
        <div>
          <label class="field-label" for="invite-query">{{ t('shared.labels.searchUsers') }}</label>
          <input class="field-input" id="invite-query" name="query" type="text" autocomplete="off" placeholder="{{ t('pages.projectMembers.invitePlaceholder') }}" data-invite-query />
          <input type="hidden" name="userId" value="" data-selected-user-id />
        </div>
        <div>
          <label class="field-label" for="invite-role">{{ t('shared.labels.role') }}</label>
          <select class="field-select" id="invite-role" name="role">
            <option value="editor">{{ t('shared.badges.editor') }}</option>
            <option value="reviewer">{{ t('shared.badges.reviewer') }}</option>
          </select>
        </div>
        <div class="rounded-3xl border border-ink/10 bg-white/60" data-invite-results hidden></div>
        <div class="flex items-center gap-3">
          <button class="btn-primary" type="submit">{{ t('shared.buttons.sendInvite') }}</button>
          <span class="text-sm text-ink/55" data-form-status></span>
        </div>
      </form>
    </section>
  {% endif %}
  {% set projectId = project.id %}
  {% include "partials/members-list.njk" %}
{% endblock %}
