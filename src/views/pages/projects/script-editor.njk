{% extends "layouts/app.njk" %}

{% block title %}{{ script.title }} · {{ t('pages.editor.heading') }}{% endblock %}

{% block content %}
  <div
    class="space-y-6"
    data-script-shell
    data-project-id="{{ project.id }}"
    data-script-id="{{ script.id }}"
    data-outline-fragment-url="/fragments/projects/{{ project.id }}/scripts/{{ script.id }}/outline-tree"
  >
    <section class="hero-panel">
      <div class="flex flex-wrap items-center gap-3">
        <span class="badge">{{ t('shared.badges.' + currentRole) }}</span>
        <span class="badge">{{ script.sceneNumberMode | upper }}</span>
        <span class="text-sm text-ink/55" data-script-connection-state>{{ t('pages.projectOverview.connecting') }}</span>
      </div>
      <h2 class="mt-4 text-4xl text-ink">{{ t('pages.editor.heading') }}</h2>
      <p class="mt-3 max-w-3xl text-lg leading-8 text-ink/70">{{ t('pages.editor.description') }}</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a class="btn-primary" href="/projects/{{ project.id }}/scripts/{{ script.id }}">{{ t('pages.scriptActions.backToOverview') }}</a>
      </div>
    </section>

    <section class="grid gap-6 xl:grid-cols-[22rem,minmax(0,1fr)]">
      <div data-outline-fragment-target>
        {% include "partials/outline-tree.njk" %}
      </div>

      <div class="space-y-6">
        <article class="panel space-y-4">
          <div class="flex items-center justify-between gap-3">
            <h3 class="text-2xl text-ink">{{ script.title }}</h3>
            <span class="badge">
              {% if permissions.canEdit %}
                {{ t('pages.editor.canEdit') }}
              {% else %}
                {{ t('pages.editor.readOnly') }}
              {% endif %}
            </span>
          </div>
          <p class="text-sm leading-7 text-ink/70">{{ t('pages.editor.placeholderBody') }}</p>
        </article>

        {% include "partials/activity-feed.njk" %}
      </div>
    </section>
  </div>
{% endblock %}
