{% extends "layouts/app.njk" %}

{% block title %}{{ project.title }} · {{ t('pages.projectSettings.heading') }}{% endblock %}

{% block content %}
  <section class="hero-panel">
    <h2 class="text-4xl text-ink">{{ t('pages.projectSettings.heading') }}</h2>
    <p class="mt-3 max-w-3xl text-lg leading-8 text-ink/70">{{ t('pages.projectSettings.description') }}</p>
  </section>
  <section class="grid gap-6 xl:grid-cols-2">
    <article class="panel">
      <form class="space-y-4" data-project-settings-form data-project-id="{{ project.id }}">
        <div>
          <label class="field-label" for="project-settings-title">{{ t('shared.labels.projectTitle') }}</label>
          <input class="field-input" id="project-settings-title" name="title" type="text" maxlength="120" value="{{ project.title }}" />
        </div>
        <div class="flex items-center gap-3">
          <button class="btn-primary" type="submit">{{ t('shared.buttons.saveProject') }}</button>
          <span class="text-sm text-ink/55" data-form-status></span>
        </div>
      </form>
    </article>
    <article class="panel">
      {% if ownershipCandidates.length %}
        <form class="space-y-4" data-ownership-transfer-form data-project-id="{{ project.id }}">
          <div>
            <label class="field-label" for="ownership-member">{{ t('shared.labels.transferOwnership') }}</label>
            <select class="field-select" id="ownership-member" name="memberId">
              {% for member in ownershipCandidates %}
                <option value="{{ member.id }}">{{ member.user.displayName }}{% if member.user.username %} (@{{ member.user.username }}){% endif %}</option>
              {% endfor %}
            </select>
          </div>
          <div class="flex items-center gap-3">
            <button class="btn-secondary" type="submit">{{ t('shared.buttons.transferOwnership') }}</button>
            <span class="text-sm text-ink/55" data-form-status></span>
          </div>
        </form>
      {% else %}
        <p class="text-sm text-ink/60">{{ t('pages.projectSettings.transferEmpty') }}</p>
      {% endif %}
    </article>
  </section>
{% endblock %}
