{% extends "layouts/app.njk" %}

{% block title %}{{ t('pages.dashboard.title') }} · {{ t('meta.appName') }}{% endblock %}

{% block content %}
  <section class="hero-panel">
    <h2 class="text-4xl text-ink">{{ t('pages.dashboard.heading') }}</h2>
    <p class="mt-3 max-w-3xl text-lg leading-8 text-ink/70">{{ t('pages.dashboard.description') }}</p>
  </section>
  <section class="grid gap-6 xl:grid-cols-[1.05fr,0.95fr]">
    <article class="panel space-y-4">
      <div class="flex items-center justify-between gap-3">
        <h3 class="text-2xl text-ink">{{ t('sections.projects') }}</h3>
        <a class="btn-secondary" href="/projects/new">{{ t('pages.newProject.title') }}</a>
      </div>
      {% if memberships.length %}
        <div class="space-y-3">
          {% for membership in memberships %}
            <article class="list-card flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
              <div>
                <p class="font-semibold text-ink">{{ membership.projectId.name }}</p>
                <p class="mt-1 text-sm text-ink/60">{{ membership.projectId.description }}</p>
              </div>
              <div class="flex flex-wrap items-center gap-3">
                <span class="badge">{{ t('shared.badges.' + membership.role) }}</span>
                <a class="btn-primary" href="/projects/{{ membership.projectId.publicId }}">{{ t('shared.buttons.openProject') }}</a>
              </div>
            </article>
          {% endfor %}
        </div>
      {% else %}
        <p class="text-sm text-ink/60">{{ t('shared.empty.projects') }}</p>
      {% endif %}
    </article>
    <article class="panel space-y-4">
      <h3 class="text-2xl text-ink">{{ t('sections.activity') }}</h3>
      {% if activity.length %}
        <div class="space-y-3">
          {% for item in activity %}
            <article class="list-card">
              <p class="font-semibold text-ink">{{ item.message }}</p>
              <p class="mt-2 text-xs text-ink/50">{{ formatDate(item.createdAt) }}</p>
            </article>
          {% endfor %}
        </div>
      {% else %}
        <p class="text-sm text-ink/60">{{ t('shared.empty.activity') }}</p>
      {% endif %}
    </article>
  </section>
{% endblock %}

