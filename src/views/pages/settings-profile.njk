{% extends "layouts/app.njk" %}

{% block title %}{{ t('pages.settingsProfile.title') }} · {{ t('meta.appName') }}{% endblock %}

{% block content %}
  <section class="hero-panel">
    <h2 class="text-4xl text-ink">{{ t('pages.settingsProfile.heading') }}</h2>
    <p class="mt-3 max-w-3xl text-lg leading-8 text-ink/70">{{ t('pages.settingsProfile.description') }}</p>
  </section>
  <section class="panel grid gap-4 md:grid-cols-2">
    <div class="panel-muted">
      <p class="field-label">{{ t('shared.labels.displayName') }}</p>
      <p class="text-lg text-ink">{{ user.displayName }}</p>
    </div>
    <div class="panel-muted">
      <p class="field-label">{{ t('shared.labels.username') }}</p>
      <p class="text-lg text-ink">@{{ user.username }}</p>
    </div>
    <div class="panel-muted">
      <p class="field-label">{{ t('shared.labels.email') }}</p>
      <p class="text-lg text-ink">{{ user.email }}</p>
    </div>
    <div class="panel-muted">
      <p class="field-label">{{ t('shared.labels.locale') }}</p>
      <p class="text-lg text-ink">{{ user.preferences.locale or user.locale }}</p>
    </div>
  </section>
  <p class="text-sm text-ink/55">{{ t('pages.settingsProfile.apiHint') }}</p>
{% endblock %}

