{% extends "layouts/app.njk" %}

{% block title %}{{ t('pages.editor.heading') }} · {{ t('meta.appName') }}{% endblock %}

{% block content %}
  <section class="hero-panel" data-editor-shell data-project-id="{{ project.publicId }}" data-script-id="{{ script.publicId }}" data-socket-namespace="/collab">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent">{{ script.publicId }}</p>
    <h2 class="mt-3 text-4xl text-ink">{{ t('pages.editor.heading') }}</h2>
    <p class="mt-3 max-w-3xl text-lg leading-8 text-ink/70">{{ t('pages.editor.description') }}</p>
    <div class="mt-5 flex flex-wrap gap-3">
      <span class="badge">{{ t('pages.editor.socketNamespace') }}: /collab</span>
      <span class="badge">
        {% if canEdit %}
          {{ t('pages.editor.canEdit') }}
        {% else %}
          {{ t('pages.editor.readOnly') }}
        {% endif %}
      </span>
    </div>
  </section>
  <section class="grid gap-6 xl:grid-cols-[1.1fr,0.9fr]">
    <article class="panel space-y-4">
      <h3 class="text-2xl text-ink">{{ scene and scene.title or t('sections.scenes') }}</h3>
      {% if scene %}
        <div class="screenplay-page rounded-3xl border border-ink/10 shadow-panel">
          <p class="whitespace-pre-line font-mono text-[12pt] leading-6 text-ink">{{ scene.headContent }}</p>
        </div>
      {% else %}
        <p class="text-sm text-ink/60">{{ t('shared.empty.generic') }}</p>
      {% endif %}
    </article>
    <div class="space-y-6">
      <article class="panel space-y-4">
        <h3 class="text-2xl text-ink">{{ t('sections.notes') }}</h3>
        {% if notes.length %}
          {% for note in notes %}
            <div class="list-card">
              <p class="text-sm leading-6 text-ink">{{ note.body }}</p>
            </div>
          {% endfor %}
        {% else %}
          <p class="text-sm text-ink/60">{{ t('shared.empty.notes') }}</p>
        {% endif %}
      </article>
      <article class="panel space-y-4">
        <h3 class="text-2xl text-ink">{{ t('sections.versions') }}</h3>
        {% if versions.length %}
          {% for version in versions %}
            <div class="list-card">
              <p class="font-semibold text-ink">{{ version.versionLabel or version.publicId }}</p>
              <p class="text-xs text-ink/50">{{ formatDate(version.savedAt) }}</p>
            </div>
          {% endfor %}
        {% else %}
          <p class="text-sm text-ink/60">{{ t('shared.empty.versions') }}</p>
        {% endif %}
      </article>
    </div>
  </section>
{% endblock %}

