{% extends "layouts/public.njk" %}

{% block title %}{{ t('pages.login.title') }} · {{ t('meta.appName') }}{% endblock %}

{% block content %}
  <section class="grid gap-6 lg:grid-cols-[1.05fr,0.95fr]">
    <article class="hero-panel space-y-5">
      <h1 class="text-4xl text-ink">{{ t('pages.login.heading') }}</h1>
      <p class="max-w-xl text-lg leading-8 text-ink/70">{{ t('pages.login.description') }}</p>
      <a class="btn-primary" href="/auth/google">{{ t('pages.login.googleCta') }}</a>
      <p class="text-sm text-ink/55">{{ t('pages.login.googleDisclaimer') }}</p>
    </article>
    <article class="panel space-y-5">
      <div>
        <h2 class="text-2xl text-ink">{{ t('pages.login.devHeading') }}</h2>
        <p class="mt-2 text-sm leading-7 text-ink/65">{{ t('pages.login.devDescription') }}</p>
      </div>
      {% if authBypassEnabled %}
        <form class="space-y-4" action="/auth/dev-login" method="post">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
          <input type="hidden" name="returnTo" value="{{ returnTo }}" />
          <label class="field-label" for="email">{{ t('shared.labels.email') }}</label>
          <select class="field-select" id="email" name="email">
            {% for user in seededUsers %}
              <option value="{{ user.email }}">{{ user.displayName }} · {{ user.email }}</option>
            {% endfor %}
          </select>
          <button class="btn-primary w-full" type="submit">{{ t('pages.login.submit') }}</button>
        </form>
      {% else %}
        <p class="rounded-2xl bg-mist/80 px-4 py-3 text-sm text-ink/70">Development auth bypass is disabled.</p>
      {% endif %}
    </article>
  </section>
{% endblock %}

