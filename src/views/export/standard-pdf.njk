{% import "export/line-macros.njk" as lineMacros %}
<!doctype html>
<html lang="{{ locale }}">
  <head>
    <meta charset="utf-8" />
    <style>{{ cssText | safe }}</style>
  </head>
  <body
    class="export-document export-document--standard"
    style="--export-font-stack: {{ layout.fontCssValue }}; --export-page-width: {{ layout.pageWidthIn }}in; --export-page-height: {{ layout.pageHeightIn }}in; --export-content-top: {{ layout.contentTopIn }}in; --export-content-line-height: {{ layout.lineHeightPt }}pt; --export-font-size: {{ layout.fontSizePt }}pt; --export-page-number-left: {{ layout.pageNumberLeftIn }}in; --export-page-number-top: {{ layout.pageNumberTopIn }}in;"
  >
    {% include "export/title-page.njk" %}

    {% for page in pages %}
      <section class="export-page export-page--standard">
        <div class="export-page__number">{{ page.pageNumber }}</div>
        <div class="export-page__content">
          {% for slot in page.lineSlots %}
            {{ lineMacros.renderLineSlot(slot) }}
          {% endfor %}
        </div>
      </section>
    {% endfor %}
  </body>
</html>

