{% extends "layouts/base.njk" %}

{% block body %}
  <div class="app-shell grid gap-6 xl:grid-cols-[18rem,minmax(0,1fr)]">
    <aside class="panel space-y-6">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-ink/45">{{ t('meta.appName') }}</p>
        <p class="mt-2 text-3xl text-ink">{{ currentUser.displayName }}</p>
        <p class="text-sm text-ink/60">
          {% if currentUser.username %}
            @{{ currentUser.username }}
          {% else %}
            {{ t('pages.settingsProfile.onboardingBadge') }}
          {% endif %}
        </p>
      </div>
      {% if onboardingRequired %}
        <div class="rounded-3xl border border-accent/20 bg-accent/10 px-4 py-4 text-sm text-ink/80">
          <p class="font-semibold text-ink">{{ t('pages.settingsProfile.onboardingHeading') }}</p>
          <p class="mt-2">{{ t('pages.settingsProfile.onboardingNotice') }}</p>
        </div>
      {% endif %}
      <nav class="space-y-2">
        {% if not onboardingRequired %}
          <a class="block rounded-2xl px-4 py-3 hover:bg-mist/70 focus-visible:bg-mist {% if pathname == '/app' %}bg-mist{% endif %}" href="/app">{{ t('nav.dashboard') }}</a>
          <a class="flex items-center justify-between rounded-2xl px-4 py-3 hover:bg-mist/70 focus-visible:bg-mist {% if pathname == '/inbox' %}bg-mist{% endif %}" href="/inbox">
            <span>{{ t('nav.inbox') }}</span>
            {% if inboxSummary and inboxSummary.unread.total %}
              <span
                class="badge"
                aria-label="{{ inboxSummary.unread.total }} unread inbox items"
                data-inbox-nav-badge
              >
                {{ inboxSummary.unread.total }}
              </span>
            {% else %}
              <span class="badge" data-inbox-nav-badge hidden>0</span>
            {% endif %}
          </a>
          <a class="block rounded-2xl px-4 py-3 hover:bg-mist/70 {% if pathname == '/settings/preferences' %}bg-mist{% endif %}" href="/settings/preferences">{{ t('nav.preferences') }}</a>
        {% endif %}
        <a class="block rounded-2xl px-4 py-3 hover:bg-mist/70 {% if pathname == '/settings/profile' %}bg-mist{% endif %}" href="/settings/profile">{{ t('nav.profile') }}</a>
      </nav>
      <div class="space-y-3 border-t border-ink/10 pt-4">
        {% include "partials/locale-switcher.njk" %}
        <form action="/logout" method="post">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
          <button class="btn-primary w-full" type="submit">{{ t('nav.logout') }}</button>
        </form>
      </div>
    </aside>
    <main id="{{ mainContentId }}" class="space-y-6" tabindex="-1">
      {% block content %}{% endblock %}
    </main>
  </div>
{% endblock %}
