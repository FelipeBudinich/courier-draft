<section class="panel space-y-3">
  <h2 class="text-xl text-ink">{{ t('fragments.members.heading') }}</h2>
  {% if members.length %}
    <div class="space-y-3">
      {% for member in members %}
        <article class="list-card space-y-3">
          <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
            <div>
              <p class="font-semibold text-ink">{{ member.user.displayName }}</p>
              <p class="text-sm text-ink/60">
                {% if member.user.username %}@{{ member.user.username }} · {% endif %}{{ member.user.email }}
              </p>
              <p class="mt-1 text-xs text-ink/50">
                {{ t('shared.labels.role') }}: {{ t('shared.badges.' + member.role) }}
                · {{ t('shared.labels.status') }}: {{ t('shared.status.' + member.status) }}
              </p>
            </div>
            <div class="flex flex-wrap items-center gap-3">
              <span class="badge">{{ t('shared.badges.' + member.role) }}</span>
              <span class="badge">{{ t('shared.status.' + member.status) }}</span>
            </div>
          </div>
          {% if canManageMembers and member.role != 'owner' and member.status == 'active' %}
            <div class="flex flex-wrap items-center gap-3">
              <form class="flex items-center gap-3" data-member-role-form data-project-id="{{ projectId }}" data-member-id="{{ member.id }}">
                <label class="text-sm font-semibold text-ink/70" for="role-{{ member.id }}">{{ t('shared.labels.role') }}</label>
                <select class="field-select w-auto min-w-36" id="role-{{ member.id }}" name="role">
                  <option value="editor" {% if member.role == 'editor' %}selected{% endif %}>{{ t('shared.badges.editor') }}</option>
                  <option value="reviewer" {% if member.role == 'reviewer' %}selected{% endif %}>{{ t('shared.badges.reviewer') }}</option>
                </select>
                <button class="btn-secondary" type="submit">{{ t('shared.buttons.save') }}</button>
              </form>
              <form data-member-remove-form data-project-id="{{ projectId }}" data-member-id="{{ member.id }}">
                <button class="btn-secondary" type="submit">{{ t('shared.buttons.removeMember') }}</button>
              </form>
            </div>
          {% elif canManageMembers and member.role != 'owner' and member.status == 'pending' %}
            <form data-member-remove-form data-project-id="{{ projectId }}" data-member-id="{{ member.id }}">
              <button class="btn-secondary" type="submit">{{ t('shared.buttons.cancelInvite') }}</button>
            </form>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% else %}
    <p class="text-sm text-ink/60">{{ t('fragments.members.empty') }}</p>
  {% endif %}
</section>
