<section class="panel space-y-3">
  <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
    <h2 class="text-xl text-ink">{{ t('fragments.activity.heading') }}</h2>
    {% if activityState %}
      <nav class="flex flex-wrap gap-2" aria-label="{{ t('fragments.activity.heading') }}">
        <a class="filter-chip {% if activityState.filter == 'all' %}is-active{% endif %}" href="/projects/{{ projectId }}/activity">{{ t('filters.all') }}</a>
        <a class="filter-chip {% if activityState.filter == 'invites' %}is-active{% endif %}" href="/projects/{{ projectId }}/activity?type=invites">{{ t('filters.invites') }}</a>
        <a class="filter-chip {% if activityState.filter == 'membership' %}is-active{% endif %}" href="/projects/{{ projectId }}/activity?type=membership">{{ t('filters.membershipChanges') }}</a>
        <a class="filter-chip {% if activityState.filter == 'activity' %}is-active{% endif %}" href="/projects/{{ projectId }}/activity?type=activity">{{ t('filters.activity') }}</a>
      </nav>
    {% endif %}
  </div>
  {% if activity.length %}
    <div class="space-y-3">
      {% for item in activity %}
        {% set occurredAt = item.createdAt or item.occurredAt %}
        {% if item.project %}
          {% set projectTitle = item.projectTitle or item.project.title %}
        {% else %}
          {% set projectTitle = item.projectTitle %}
        {% endif %}
        {% if item.href %}
          {% set href = item.href %}
        {% elif item.activity %}
          {% set href = item.activity.href %}
        {% else %}
          {% set href = null %}
        {% endif %}
        <article class="list-card {% if item.read is defined and not item.read %}border-accent/30 bg-accent/5{% endif %}">
          <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
            <div>
              <div class="flex flex-wrap items-center gap-2">
                {% if item.category %}
                  <span class="badge">{{ t('filters.' + item.category) }}</span>
                {% endif %}
                {% if projectTitle %}
                  <p class="text-sm text-ink/60">{{ projectTitle }}</p>
                {% endif %}
              </div>
              <p class="mt-2 font-semibold text-ink">{{ item.message }}</p>
              <p class="mt-1 text-xs text-ink/50">{{ formatDate(occurredAt) }}</p>
            </div>
            {% if href %}
              <a class="btn-secondary" href="{{ href }}">{{ t('shared.buttons.open') }}</a>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  {% else %}
    <p class="text-sm text-ink/60">{{ t('fragments.activity.empty') }}</p>
  {% endif %}
  {% if activityState and activityState.pagination.totalPages > 1 %}
    <nav class="flex flex-wrap items-center justify-between gap-3" aria-label="{{ t('shared.labels.pagination') }}">
      {% if activityState.pagination.hasPreviousPage %}
        <a
          class="btn-secondary"
          href="/projects/{{ projectId }}/activity?type={{ activityState.filter }}&page={{ activityState.pagination.page - 1 }}"
        >
          {{ t('shared.buttons.previous') }}
        </a>
      {% else %}
        <span></span>
      {% endif %}
      <p class="text-sm text-ink/60">
        {{ activityState.pagination.page }} / {{ activityState.pagination.totalPages }}
      </p>
      {% if activityState.pagination.hasNextPage %}
        <a
          class="btn-secondary"
          href="/projects/{{ projectId }}/activity?type={{ activityState.filter }}&page={{ activityState.pagination.page + 1 }}"
        >
          {{ t('shared.buttons.next') }}
        </a>
      {% endif %}
    </nav>
  {% endif %}
</section>
