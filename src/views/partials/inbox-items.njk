<section
  class="panel space-y-4"
  data-inbox-items
  data-current-filter="{{ inbox.filter }}"
  data-current-page="{{ inbox.pagination.page }}"
>
  <div class="flex items-center justify-between gap-3">
    <h2 class="text-2xl text-ink">{{ t('pages.inbox.title') }}</h2>
    <span class="badge">{{ inbox.pagination.totalItems }}</span>
  </div>
  {% if inbox.items.length %}
    <div class="space-y-3">
      {% for item in inbox.items %}
        <article
          class="list-card space-y-3 {% if not item.read %}border-accent/30 bg-accent/5{% endif %}"
          data-inbox-item-id="{{ item.id }}"
          data-inbox-item-read="{{ 'true' if item.read else 'false' }}"
        >
          <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
            <div class="space-y-2">
              <div class="flex flex-wrap items-center gap-2">
                <span class="badge">{{ t('filters.' + item.category) }}</span>
                {% if item.project %}
                  <a class="text-sm font-semibold text-ink underline-offset-4 hover:underline" href="/projects/{{ item.project.id }}">{{ item.project.title }}</a>
                {% endif %}
                {% if not item.read %}
                  <span class="badge bg-accent/15 text-accent">{{ t('shared.labels.unread') }}</span>
                {% endif %}
              </div>
              <p class="font-semibold text-ink">{{ item.message }}</p>
              <p class="text-sm text-ink/60">
                {% if item.actor and item.actor.displayName %}
                  {{ item.actor.displayName }} ·
                {% endif %}
                {{ formatDate(item.occurredAt) }}
              </p>
            </div>
            <div class="flex flex-wrap gap-2">
              {% if item.href %}
                <a class="btn-secondary" href="{{ item.href }}">{{ t('shared.buttons.open') }}</a>
              {% endif %}
              {% if not item.read %}
                <button class="btn-secondary" type="button" data-inbox-mark-read="{{ item.id }}">
                  {{ t('shared.buttons.markRead') }}
                </button>
              {% endif %}
            </div>
          </div>

          {% if item.kind == 'invite' and item.invite.status == 'pending' %}
            <div class="flex flex-wrap gap-3">
              <form data-invite-action-form action="/api/v1/invites/{{ item.invite.id }}/accept" method="post">
                <button class="btn-primary" type="submit">{{ t('shared.buttons.acceptInvite') }}</button>
              </form>
              <form data-invite-action-form action="/api/v1/invites/{{ item.invite.id }}/decline" method="post">
                <button class="btn-secondary" type="submit">{{ t('shared.buttons.declineInvite') }}</button>
              </form>
            </div>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% else %}
    <div class="rounded-3xl border border-dashed border-ink/20 px-5 py-6 text-sm text-ink/70">
      <p class="font-semibold text-ink">{{ t('pages.inbox.emptyHeading') }}</p>
      <p class="mt-2">{{ t('pages.inbox.emptyBody') }}</p>
    </div>
  {% endif %}
  {% if inbox.pagination.totalPages > 1 %}
    <nav class="flex flex-wrap items-center justify-between gap-3" aria-label="{{ t('shared.labels.pagination') }}">
      {% if inbox.pagination.hasPreviousPage %}
        <a
          class="btn-secondary"
          href="/inbox?filter={{ inbox.filter }}&page={{ inbox.pagination.page - 1 }}"
        >
          {{ t('shared.buttons.previous') }}
        </a>
      {% else %}
        <span></span>
      {% endif %}
      <p class="text-sm text-ink/60">
        {{ inbox.pagination.page }} / {{ inbox.pagination.totalPages }}
      </p>
      {% if inbox.pagination.hasNextPage %}
        <a
          class="btn-secondary"
          href="/inbox?filter={{ inbox.filter }}&page={{ inbox.pagination.page + 1 }}"
        >
          {{ t('shared.buttons.next') }}
        </a>
      {% endif %}
    </nav>
  {% endif %}
</section>
