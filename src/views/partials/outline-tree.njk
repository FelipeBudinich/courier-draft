{% macro renderOutlineNodes(nodes, permissions) %}
  <ol class="space-y-3">
    {% for node in nodes %}
      <li class="space-y-3">
        <article
          class="list-card space-y-3"
          data-outline-item
          data-node-id="{{ node.id }}"
          data-node-type="{{ node.type }}"
          data-parent-id="{{ node.placementParentId or '' }}"
          {% if permissions and permissions.canEdit %}draggable="true"{% endif %}
        >
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div class="space-y-1">
              <div class="flex flex-wrap items-center gap-2">
                {% if node.displaySceneNumber %}
                  <span class="badge">{{ node.displaySceneNumber }}</span>
                {% endif %}
                <span class="badge">{{ node.type }}</span>
                <p class="font-semibold text-ink">{{ node.title }}</p>
              </div>
              {% if node.type == 'scene' %}
                <p class="text-xs text-ink/55">
                  Act: {{ node.actId or 'none' }} · Beat: {{ node.beatId or 'none' }}
                </p>
              {% else %}
                <p class="text-xs text-ink/55">{{ node.positionKey }}</p>
              {% endif %}
            </div>

            {% if permissions and permissions.canEdit %}
              <div class="flex flex-wrap gap-2">
                {% if node.type == 'act' %}
                  <button class="btn-secondary" type="button" data-outline-create data-node-type="beat" data-parent-id="{{ node.id }}">{{ t('pages.scriptActions.addBeat') }}</button>
                  <button class="btn-secondary" type="button" data-outline-create data-node-type="scene" data-parent-id="{{ node.id }}">{{ t('pages.scriptActions.addScene') }}</button>
                {% elif node.type == 'beat' %}
                  <button class="btn-secondary" type="button" data-outline-create data-node-type="scene" data-parent-id="{{ node.id }}">{{ t('pages.scriptActions.addScene') }}</button>
                {% endif %}
                <button class="btn-secondary" type="button" data-outline-rename data-node-id="{{ node.id }}" data-current-title="{{ node.title }}">{{ t('pages.scriptActions.rename') }}</button>
                <button class="btn-secondary" type="button" data-outline-delete data-node-id="{{ node.id }}" data-node-type="{{ node.type }}">{{ t('pages.scriptActions.delete') }}</button>
              </div>
            {% endif %}
          </div>
        </article>

        {% if node.canHaveChildren %}
          <div class="ml-5 border-l border-ink/10 pl-4" data-outline-container data-parent-id="{{ node.id }}">
            {% if node.children.length %}
              {{ renderOutlineNodes(node.children, permissions) }}
            {% elseif permissions and permissions.canEdit %}
              <p class="rounded-2xl border border-dashed border-ink/10 px-4 py-3 text-xs text-ink/50">
                {{ t('pages.scriptSections.dropHint') }}
              </p>
            {% endif %}
          </div>
        {% endif %}
      </li>
    {% endfor %}
  </ol>
{% endmacro %}

<section class="panel space-y-4" data-outline-root>
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h2 class="text-xl text-ink">{{ t('fragments.outline.heading') }}</h2>
      {% if script %}
        <p class="text-sm text-ink/60">{{ t('pages.scriptSections.outlineMode') }}: {{ script.sceneNumberMode | upper }}</p>
      {% endif %}
    </div>
    {% if permissions and permissions.canEdit %}
      <div class="flex flex-wrap gap-2">
        <button class="btn-secondary" type="button" data-outline-create data-node-type="act">{{ t('pages.scriptActions.addAct') }}</button>
        <button class="btn-secondary" type="button" data-outline-create data-node-type="beat">{{ t('pages.scriptActions.addBeat') }}</button>
        <button class="btn-secondary" type="button" data-outline-create data-node-type="scene">{{ t('pages.scriptActions.addScene') }}</button>
      </div>
    {% endif %}
  </div>

  {% if outlineNodes.length %}
    <div data-outline-container data-parent-id="">
      {{ renderOutlineNodes(outlineNodes, permissions) }}
    </div>
  {% else %}
    <p class="text-sm text-ink/60">{{ t('fragments.outline.empty') }}</p>
  {% endif %}
</section>
