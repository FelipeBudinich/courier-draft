{
  "name": "courier-draft",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:tailwind:watch\" \"npm:editor:watch\"",
    "dev:server": "nodemon --watch src --watch locales --watch public/js --watch src/views --ext js,njk,json src/server.js",
    "build": "npm run tailwind:build && npm run editor:build",
    "editor:build": "node scripts/build-editor.js",
    "editor:watch": "node scripts/build-editor.js --watch",
    "tailwind:build": "tailwindcss -i ./public/css/app.css -o ./public/build/app.css --minify",
    "tailwind:watch": "tailwindcss -i ./public/css/app.css -o ./public/build/app.css --watch",
    "lint": "eslint .",
    "start": "node src/server.js",
    "seed": "node scripts/seed.js",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:server": "node scripts/playwright-server.js",
    "heroku-postbuild": "npm run build"
  },
  "dependencies": {
    "connect-mongo": "^5.1.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "mongoose": "^8.9.0",
    "nunjucks": "^3.2.4",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.8",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.50.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "esbuild": "^0.28.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.9",
    "playwright": "^1.50.1",
    "postcss": "^8.4.49",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.17",
    "vitest": "^3.0.4"
  }
}
